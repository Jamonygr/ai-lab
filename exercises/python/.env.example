# Copy this file to .env after terraform apply.
# Keep .env local. It contains keys and is ignored by git.

# Required for the default lab exercises.
AZURE_AI_SERVICES_ENDPOINT=<terraform-output-exercise-environment-AZURE_AI_SERVICES_ENDPOINT>
AZURE_AI_SERVICES_KEY=<terraform-output-raw-ai_services_key>
AZURE_AI_SERVICES_REGION=westeurope
CONTENT_SAFETY_ENDPOINT=<terraform-output-exercise-environment-CONTENT_SAFETY_ENDPOINT>
CONTENT_SAFETY_KEY=<terraform-output-raw-content_safety_key>

# Optional Search/RAG exercises. Set these when deploy_ai_search = true.
AI_SEARCH_ENDPOINT=<terraform-output-exercise-environment-AI_SEARCH_ENDPOINT>
AI_SEARCH_KEY=<terraform-output-raw-ai_search_admin_key>
AI_SEARCH_INDEX=ai-lab-docs
AI_SEARCH_ADVANCED_INDEX=ai-lab-rag-advanced

# Optional Document Intelligence exercise. Set these when deploy_document_intelligence = true.
DOCUMENT_INTELLIGENCE_ENDPOINT=<terraform-output-exercise-environment-DOCUMENT_INTELLIGENCE_ENDPOINT>
DOCUMENT_INTELLIGENCE_KEY=<terraform-output-raw-document_intelligence_key>
DOCUMENT_INTELLIGENCE_SAMPLE_URL=https://raw.githubusercontent.com/Azure-Samples/cognitive-services-REST-api-samples/master/curl/form-recognizer/sample-layout.pdf

# Optional Vision sample override.
VISION_SAMPLE_URL=https://learn.microsoft.com/azure/ai-services/computer-vision/media/quickstarts/presentation.png

# Optional Azure OpenAI and Foundry exercises. Set these when the related feature flags are true.
AZURE_OPENAI_ENDPOINT=<terraform-output-exercise-environment-AZURE_OPENAI_ENDPOINT>
AZURE_OPENAI_KEY=<terraform-output-raw-azure_openai_key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini-lab
FOUNDRY_HUB_DISCOVERY_URL=<terraform-output-exercise-environment-FOUNDRY_HUB_DISCOVERY_URL>
FOUNDRY_PROJECT_ID=<terraform-output-exercise-environment-FOUNDRY_PROJECT_ID>

# Optional app/evaluation telemetry.
APPLICATIONINSIGHTS_CONNECTION_STRING=<terraform-output-raw-application_insights_connection_string>
