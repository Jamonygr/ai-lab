# Copy this file to .env after terraform apply.
# Keep .env local. It contains keys and is ignored by git.

AZURE_AI_SERVICES_ENDPOINT=<terraform output ai_services_endpoint>
AZURE_AI_SERVICES_KEY=<terraform output -raw ai_services_key>
AZURE_AI_SERVICES_REGION=westeurope

CONTENT_SAFETY_ENDPOINT=<terraform output content_safety_endpoint>
CONTENT_SAFETY_KEY=<terraform output -raw content_safety_key>

# Optional Search/RAG exercise. Set these only when deploy_ai_search = true.
AI_SEARCH_ENDPOINT=<terraform output ai_search_endpoint>
AI_SEARCH_KEY=<terraform output -raw ai_search_admin_key>
AI_SEARCH_INDEX=ai-lab-docs

# Optional Azure OpenAI extension. Set these only when deploy_azure_openai = true.
AZURE_OPENAI_ENDPOINT=<terraform output azure_openai_endpoint>
AZURE_OPENAI_KEY=<terraform output -raw azure_openai_key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini-lab
